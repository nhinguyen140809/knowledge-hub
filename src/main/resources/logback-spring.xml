<?xml version="1.0" encoding="UTF-8"?>
<!--
  Application logging. Every line carries the request's trace id (from TraceIdFilter, via the MDC)
  so a single failing request can be reconstructed from the logs. Lifecycle events log at INFO,
  developer detail at DEBUG. Never log secrets or credential material.
-->
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Human-readable, trace-tagged console output for local development. -->
  <springProfile name="dev">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId:-no-trace}] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="com.knowledgehub" level="DEBUG"/>
  </springProfile>

  <!-- Compact, single-line, trace-tagged output for server and cloud deployments. -->
  <springProfile name="prod,cloud">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%X{traceId:-no-trace}] %logger{40} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <!-- Fallback for any other (or no) active profile, e.g. tests. -->
  <springProfile name="!dev &amp; !prod &amp; !cloud">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId:-no-trace}] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>
</configuration>
