{
  "name": "knowledge-hub",
  "image": "mcr.microsoft.com/devcontainers/java:21-bookworm",

  // Docker-in-Docker so `docker compose` and Testcontainers work inside the Codespace.
  // Node runs the frontend/ toolchain (Vite dev server + build) and the Claude Code CLI.
  // Pinned to 24 (current LTS) for reproducible builds; pnpm is added in post-create.sh.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "24" },
    // python3 is preinstalled but without pip/venv — needed for perf/ (perf/README.md)
    "ghcr.io/devcontainers/features/python:1": { "installTools": false }
  },

  "forwardPorts": [8000, 5173, 7474, 7687, 6333, 6334],
  "portsAttributes": {
    "8000": { "label": "app (REST + MCP)" },
    "5173": { "label": "frontend" },
    "7474": { "label": "neo4j browser" },
    "7687": { "label": "neo4j bolt" },
    "6333": { "label": "qdrant dashboard" },
    "6334": { "label": "qdrant gRPC" }
  },

  // Codespaces secrets (Settings > Codespaces secrets) / host env vars are resolved here,
  // once, only for this command — NOT via containerEnv, which would bake them (often empty,
  // if unset on the host) into every later shell and permanently shadow .env edits, since
  // docker compose and `just`'s dotenv-load both treat an already-exported var (even empty)
  // as set and skip reading .env for it. Unset ones simply resolve to "" here; post-create.sh
  // leaves those blank in .env for you to fill in by hand.
  "postCreateCommand": "NEO4J_PASSWORD='${localEnv:NEO4J_PASSWORD}' API_KEY='${localEnv:API_KEY}' EMBEDDING_API_KEY='${localEnv:EMBEDDING_API_KEY}' EMBEDDING_PROVIDER='${localEnv:EMBEDDING_PROVIDER}' EMBEDDING_MODEL='${localEnv:EMBEDDING_MODEL}' EMBEDDING_BASE_URL='${localEnv:EMBEDDING_BASE_URL}' EMBEDDING_DIMENSION='${localEnv:EMBEDDING_DIMENSION}' bash .devcontainer/post-create.sh",

  // Runs on every Codespace *start* (including resume from stopped). Brings the
  // datastores up automatically so you can `just dev` right away. Use `just up`
  // yourself when you want the full app container too.
  "postStartCommand": "docker compose up -d neo4j qdrant && echo 'Neo4j + Qdrant up — run: just dev (app on host) or just up (full stack in containers)'",

  // Recommend at least 4-core / 16GB for a comfortable build + 3 containers.
  // 2-core / 8GB works but is tight while Maven builds and all containers run.
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.vscode-yaml",
        "anthropic.claude-code",
        "oxc.oxc-vscode",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "skellock.just",
        "ms-python.python"
      ]
    }
  }
}