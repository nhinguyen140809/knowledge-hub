# Copy to .env and fill in. Never commit .env.

# --- Core ---
NEO4J_PASSWORD=knowledgehub
SPRING_PROFILES_ACTIVE=prod
API_KEY=                       # bootstrap admin secret + bearer token for /mcp (blank = no admin seeded)

# --- Embedding model (OpenAI-compatible: OpenAI, Voyage AI, or a local server) ---
# Switch provider/model by editing these only — no code change, no image rebuild.
# NOTE: changing the model/dimension after data exists requires re-indexing (the
# dimension is baked into the Qdrant collection). Change it before first ingest.
EMBEDDING_PROVIDER=api                        # api (remote, needs key) | local (OpenAI-compatible server, key optional)
EMBEDDING_MODEL=text-embedding-3-small        # e.g. text-embedding-3-small | voyage-3 | voyage-code-3
EMBEDDING_BASE_URL=https://api.openai.com     # OpenAI: https://api.openai.com | Voyage: https://api.voyageai.com | local: http://host:port
EMBEDDING_API_KEY=                            # provider key; for a keyless local server use any placeholder (e.g. "local")
EMBEDDING_DIMENSION=1536                       # MUST match the model: 1536 (text-embedding-3-small), 1024 (voyage-3/voyage-code-3)
# EMBEDDING_RETRY_MAX_ATTEMPTS=3               # optional tuning (defaults shown)
# EMBEDDING_RETRY_BACKOFF_MS=500
