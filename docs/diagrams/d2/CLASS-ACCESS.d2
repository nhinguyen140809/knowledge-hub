# Class Diagram — access submodule (authentication + ACL, Clean Architecture)
# Detailed class view of the security context; the data-side views are CLASS-INDEXING.d2 /
# CLASS-RETRIEVAL.d2 and the whole-system map is MODULE-ARCHITECTURE.d2. Packaged by layer
# (domain / application / inbound / infrastructure). Dependencies point inward; infrastructure
# realizes domain ports. Two-step model: authentication resolves a credential to a principal
# (Authenticator), authorization computes the readable sources of a principal (Authorizer).
# Render:  d2 CLASS-ACCESS.d2 class-access.svg     (or .pdf for LaTeX)
vars: {
  d2-config: {
    layout-engine: elk
    pad: 16
  }
}
# direction: right

classes: {
  port: {
    style.fill: "#2563eb"
    style.stroke: "#eef6ff"
  }
  service: {
    style.fill: "#059669"
    style.stroke: "#ecfdf5"
  }
  enum: {
    style.fill: "#7c3aed"
    style.stroke: "#f5f3ff"
  }
}

domain: "domain — model + ports" {
  Authenticator: {
    shape: class
    class: port
    +authenticate(bearerSecret): "Optional<AuthenticatedPrincipal>"
  }
  Authorizer: {
    shape: class
    class: port
    +readableSources(principal): "Set<String>"
    +isAdmin(principal): boolean
  }
  CredentialRepository: {
    shape: class
    class: port
    "+save(id, principalId, name, hash, createdAt)"
    "+existsActiveByPrincipalAndName(principalId, name)": boolean
    "+touchLastUsed(hash, when)"
    +revoke(id)
  }
  PrincipalRepository: {
    shape: class
    class: port
    +save(principal): Principal
    +existsByRole(role): boolean
    "+addMember(groupId, memberId)"
    +deleteById(id)
  }
  GrantRepository: {
    shape: class
    class: port
    "+grant(principalId, sourceIds)"
    "+revoke(principalId, sourceIds)"
  }
  SystemConfigRepository: {
    shape: class
    class: port
    +defaultPolicy(): DefaultPolicy
    +setDefaultPolicy(policy)
  }
  Principal: {
    shape: class
    -principalId: String
    -type: PrincipalType
    -role: Role
  }
  Credential: {
    shape: class
    -credentialId: String
    -name: String
    -revoked: boolean
  }
  Grant: {
    shape: class
    -principalId: String
    -sourceIds: "List<String>"
  }
  AuthenticatedPrincipal: {
    shape: class
    -principalId: String
    -role: Role
  }
  PrincipalType: {
    shape: class
    class: enum
    SUBJECT: ""
    GROUP: ""
  }
  Role: {
    shape: class
    class: enum
    ADMIN: ""
    MEMBER: ""
  }
  DefaultPolicy: {
    shape: class
    class: enum
    DENY: ""
    ALLOW: ""
  }
}

collaborators: "collaborators — other contexts" {
  SourceRepository: {
    shape: class
    class: port
    "knowledge.ingestion": ""
    +existsById(sourceId): boolean
  }
}

application: "application — services" {
  AuthenticationService: {
    shape: class
    class: service
    +authenticate(bearerSecret): "Optional<AuthenticatedPrincipal>"
  }
  AuthorizationService: {
    shape: class
    class: service
    +readableSources(principal): "Set<String>"
    +isAdmin(principal): boolean
  }
  CredentialService: {
    shape: class
    class: service
    +issue(principalId, name): IssuedCredential
    +revoke(credentialId)
    +list(principalId): "List<Credential>"
  }
  PrincipalAdminService: {
    shape: class
    class: service
    +create(principalId, type, role): Principal
    "+addMember(groupId, memberId)"
    +delete(principalId)
  }
  IssuedCredential: {
    shape: class
    -credentialId: String
    -name: String
    -secret: String
  }
}

inbound: "inbound adapters — REST" {
  PrincipalController: {
    shape: class
    +create(req)
    +issueCredential(id, req)
  }
  GrantController: {
    shape: class
    +grant(req)
    +revoke(req)
  }
  PolicyController: {
    shape: class
    +setPolicy(req)
  }
  CredentialController: {
    shape: class
    +revoke(id)
  }
}

infraSecurity: "infrastructure — security (filter chain)" {
  BearerAuthFilter: {
    shape: class
    "extends OncePerRequestFilter": ""
    +doFilterInternal(req, res, chain)
  }
  AclFilterProvider: {
    shape: class
    "+currentAllowedSources()": "Set<String>"
  }
  ProblemSecurityHandler: {
    shape: class
    +commence(...): "401 / 403 ProblemDetail"
  }
  SecurityConfig: {
    shape: class
    +filterChain(http): SecurityFilterChain
  }
}

infraPersist: "infrastructure — Neo4j repository adapters" {
  Neo4jCredentialAdapter: {shape: class}
  Neo4jPrincipalAdapter: {shape: class}
  Neo4jGrantAdapter: {shape: class}
  Neo4jSystemConfigAdapter: {shape: class}
}

infraLifecycle: "infrastructure — lifecycle" {
  AdminBootstrapInitializer: {
    shape: class
    "ApplicationRunner — seed admin on boot": ""
  }
  CredentialRetentionJob: {
    shape: class
    "@Scheduled — purge revoked credentials": ""
  }
}

# services realize the domain ports (dashed, hollow triangle)
application.AuthenticationService -> domain.Authenticator: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
application.AuthorizationService -> domain.Authorizer: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}

# each service depends only on the repositories/ports it needs (dependency inward)
application.AuthenticationService -> domain.CredentialRepository: {style.stroke-dash: 4}
application.AuthorizationService -> domain.GrantRepository: {style.stroke-dash: 4}
application.AuthorizationService -> domain.SystemConfigRepository: {style.stroke-dash: 4}
application.AuthorizationService -> collaborators.SourceRepository: "restricted-set (default_policy=allow)" {style.stroke-dash: 4}
application.CredentialService -> domain.CredentialRepository: {style.stroke-dash: 4}
application.CredentialService -> domain.PrincipalRepository: {style.stroke-dash: 4}
application.PrincipalAdminService -> domain.PrincipalRepository: {style.stroke-dash: 4}
application.PrincipalAdminService -> domain.GrantRepository: {style.stroke-dash: 4}
application.PrincipalAdminService -> domain.SystemConfigRepository: {style.stroke-dash: 4}
application.PrincipalAdminService -> domain.Authorizer: {style.stroke-dash: 4}

# inbound REST controllers drive the admin services
inbound.PrincipalController -> application.PrincipalAdminService: {style.stroke-dash: 4}
inbound.PrincipalController -> application.CredentialService: {style.stroke-dash: 4}
inbound.GrantController -> application.PrincipalAdminService: {style.stroke-dash: 4}
inbound.PolicyController -> application.PrincipalAdminService: {style.stroke-dash: 4}
inbound.CredentialController -> application.CredentialService: {style.stroke-dash: 4}

# security chain: authn on every request, ACL provider feeds the retrieval context
infraSecurity.SecurityConfig -> infraSecurity.BearerAuthFilter: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
infraSecurity.BearerAuthFilter -> domain.Authenticator: {style.stroke-dash: 4}
infraSecurity.BearerAuthFilter -> infraSecurity.ProblemSecurityHandler: {style.stroke-dash: 4}
infraSecurity.AclFilterProvider -> domain.Authorizer: "consumed by retrieval\n(allowed sources)" {style.stroke-dash: 4}

# lifecycle adapters use the repositories directly
infraLifecycle.AdminBootstrapInitializer -> domain.PrincipalRepository: {style.stroke-dash: 4}
infraLifecycle.AdminBootstrapInitializer -> domain.CredentialRepository: {style.stroke-dash: 4}
infraLifecycle.CredentialRetentionJob -> domain.CredentialRepository: {style.stroke-dash: 4}

# infrastructure realizes the domain repository ports (dashed, hollow triangle)
infraPersist.Neo4jCredentialAdapter -> domain.CredentialRepository: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraPersist.Neo4jPrincipalAdapter -> domain.PrincipalRepository: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraPersist.Neo4jGrantAdapter -> domain.GrantRepository: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraPersist.Neo4jSystemConfigAdapter -> domain.SystemConfigRepository: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
