# Class Diagram — retrieval submodule (Clean Architecture + parallel Pipes & Filters)
# Detailed class view of the read side; the write-side counterpart is CLASS-INDEXING.d2 and the
# whole-system module map is MODULE-ARCHITECTURE.d2. Packaged by layer (domain / application /
# inbound / infrastructure). Dependencies point inward; infrastructure realizes domain ports.
# The application layer is a SCATTER-GATHER pipeline: semantic + keyword paths fan out in
# parallel, graph expansion seeds from them, then RRF fusion fans in — see PIPELINE-RETRIEVAL.d2.
# Render:  d2 CLASS-RETRIEVAL.d2 class-retrieval.svg     (or .pdf for LaTeX)
vars: {
  d2-config: {
    layout-engine: elk
    pad: 16
  }
}
# direction: right

classes: {
  port: {
    style.fill: "#2563eb"
    style.stroke: "#eef6ff"
  }
  stage: {
    style.fill: "#059669"
    style.stroke: "#ecfdf5"
  }
  event: {
    style.fill: "#d97706"
    style.stroke: "#fef3c7"
  }
}

domain: "domain — model + ports" {
  Query: {
    shape: class
    -text: String
    -params: QueryParams
  }
  QueryParams: {
    shape: class
    -topK: Integer
    -ref: String
    -type: String
  }
  Hit: {
    shape: class
    -id: String
    -relevanceScore: double
    -metadata: HitMetadata
  }
  RankedResult: {
    shape: class
    -hits: "List<Hit>"
    -servedFromCanonicalRef: boolean
  }
  KeywordSearchPort: {
    shape: class
    class: port
    "+search(keywords, k, filter)": "List<ScoredId>"
  }
  GraphTraversalPort: {
    shape: class
    class: port
    "+expand(seedIds, k, filter)": "List<ScoredId>"
  }
  RetrievalReadPort: {
    shape: class
    class: port
    "+loadMetadata(ids, filter)": "Map<String,HitMetadata>"
    "+refIndexed(ref, filter)": boolean
  }
  FusionStrategy: {
    shape: class
    class: port
    "+fuse(lists, rrfK)": "List<ScoredId>"
  }
}

collaborators: "collaborators — other contexts (ports/events reused here)" {
  EmbeddingPort: {
    shape: class
    class: port
    "knowledge.domain": ""
    +embedBatch(texts): "List<float[]>"
  }
  VectorStorePort: {
    shape: class
    class: port
    "knowledge.domain": ""
    "+search(q, k, filter)": "List<ScoredId>"
  }
  AclFilterProvider: {
    shape: class
    "access.infrastructure": ""
    +currentAllowedSources(): "Set<String>"
  }
  IndexCompleted: {
    shape: class
    class: event
    "knowledge.sync": ""
    +sourceId: String
  }
}

application: "application — pipes & filters (scatter-gather)" {
  RetrievalService: {
    shape: class
    "+retrieve(query, allowedSources)": RankedResult
  }
  RetrievalContext: {
    shape: class
    -query: Query
    -aclFilter: Filter
    -semanticHits: "List<ScoredId>"
    -keywordHits: "List<ScoredId>"
    -assembledHits: "List<Hit>"
    -result: RankedResult
  }
  PrepareQueryStage: {
    shape: class
    class: stage
    +apply(ctx): RetrievalContext
  }
  SemanticSearchStage: {
    shape: class
    class: stage
    +apply(ctx): RetrievalContext
  }
  KeywordSearchStage: {
    shape: class
    class: stage
    +apply(ctx): RetrievalContext
  }
  GraphTraversalStage: {
    shape: class
    class: stage
    +apply(ctx): RetrievalContext
  }
  RrfFusionStage: {
    shape: class
    class: stage
    +apply(ctx): RetrievalContext
  }
  AssembleResultStage: {
    shape: class
    class: stage
    +apply(ctx): RetrievalContext
  }
  AclFilterStage: {
    shape: class
    class: stage
    "+apply(ctx): ref/type + top-k cut": RetrievalContext
  }
}

inbound: "inbound adapters" {
  RetrievalController: {
    shape: class
    +query(req): RankedResultResponse
  }
  RetrievalTools: {
    shape: class
    +queryKnowledge(text, topK, ref, type): RankedResult
  }
}

infraSearch: "infrastructure — search + fusion adapters" {
  Neo4jKeywordSearcher: {
    shape: class
    "+search(keywords, k, filter)"
  }
  Neo4jGraphTraverser: {
    shape: class
    "+expand(seedIds, k, filter)"
  }
  Neo4jRetrievalReader: {
    shape: class
    +loadMetadata(ids, filter)
    +refIndexed(ref, filter)
  }
  RrfFusion: {
    shape: class
    "+fuse(lists, rrfK)"
  }
}

infraCache: "infrastructure — cache" {
  RetrievalCache: {
    shape: class
    "+get(query, allowed, loader)": RankedResult
    +invalidate()
  }
  CacheInvalidationListener: {
    shape: class
    +onIndexCompleted(evt)
  }
}

# inbound adapters drive the service; each first resolves the caller's allowed sources
inbound.RetrievalController -> application.RetrievalService: {style.stroke-dash: 4}
inbound.RetrievalTools -> application.RetrievalService: {style.stroke-dash: 4}
inbound.RetrievalController -> collaborators.AclFilterProvider: {style.stroke-dash: 4}
inbound.RetrievalTools -> collaborators.AclFilterProvider: {style.stroke-dash: 4}

# service caches results and owns the ordered stages (filled diamond = composition)
application.RetrievalService -> infraCache.RetrievalCache: {style.stroke-dash: 4}
application.RetrievalService -> application.PrepareQueryStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.RetrievalService -> application.SemanticSearchStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.RetrievalService -> application.KeywordSearchStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.RetrievalService -> application.GraphTraversalStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.RetrievalService -> application.RrfFusionStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.RetrievalService -> application.AssembleResultStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.RetrievalService -> application.AclFilterStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}

# the pipe: scatter (semantic ∥ keyword) -> graph seeds from them -> fuse -> assemble -> final cut
application.PrepareQueryStage -> application.SemanticSearchStage: parallel
application.PrepareQueryStage -> application.KeywordSearchStage: parallel
application.SemanticSearchStage -> application.GraphTraversalStage
application.KeywordSearchStage -> application.GraphTraversalStage
application.GraphTraversalStage -> application.RrfFusionStage -> application.AssembleResultStage -> application.AclFilterStage

# each filter depends only on the ports it needs (dependency inward)
application.SemanticSearchStage -> collaborators.EmbeddingPort: {style.stroke-dash: 4}
application.SemanticSearchStage -> collaborators.VectorStorePort: {style.stroke-dash: 4}
application.KeywordSearchStage -> domain.KeywordSearchPort: {style.stroke-dash: 4}
application.GraphTraversalStage -> domain.GraphTraversalPort: {style.stroke-dash: 4}
application.RrfFusionStage -> domain.FusionStrategy: {style.stroke-dash: 4}
application.AssembleResultStage -> domain.RetrievalReadPort: {style.stroke-dash: 4}
application.RetrievalService -> domain.RetrievalReadPort: "refIndexed" {style.stroke-dash: 4}

# infrastructure realizes the domain ports (dashed, hollow triangle)
infraSearch.Neo4jKeywordSearcher -> domain.KeywordSearchPort: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraSearch.Neo4jGraphTraverser -> domain.GraphTraversalPort: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraSearch.Neo4jRetrievalReader -> domain.RetrievalReadPort: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraSearch.RrfFusion -> domain.FusionStrategy: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}

# cache invalidation reacts to the write side's completion event
collaborators.IndexCompleted -> infraCache.CacheInvalidationListener: "@EventListener" {style.stroke-dash: 4}
infraCache.CacheInvalidationListener -> infraCache.RetrievalCache: {style.stroke-dash: 4}
