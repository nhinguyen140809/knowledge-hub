# Class Diagram — knowledge / indexing submodule (Clean Architecture + Pipes & Filters)
# Detailed class view of ONE submodule; for the whole-system module map see
# COMPONENT-DIAGRAM.d2, and for the other detailed views CLASS-RETRIEVAL.d2 / CLASS-ACCESS.d2.
# Packaged by layer (domain / application / inbound / infrastructure). Dependencies point
# inward; infrastructure realizes domain ports. The application layer is a PIPELINE of
# single-responsibility FILTERS (stages) over a shared context — pipes & filters layered on
# top of Clean Architecture. The `retrieval` submodule mirrors this as a parallel
# (scatter-gather) pipeline — see CLASS-RETRIEVAL.d2 and PIPELINE-RETRIEVAL.d2.
# Render:  d2 CLASS-INDEXING.d2 class-indexing.svg     (or .pdf for LaTeX)
vars: {
  d2-config: {
    layout-engine: dagre
    pad: 16
  }
}
# direction: right

classes: {
  port: {
    style.fill: "#2563eb"
    style.stroke: "#eef6ff"
  }
  stage: {
    style.fill: "#059669"
    style.stroke: "#ecfdf5"
  }
  event: {
    style.fill: "#d97706"
    style.stroke: "#fef3c7"
  }
}

domain: "domain — model + ports" {
  Chunk: {
    shape: class
    -chunkId: String
    -contentHash: String
    -text: String
  }
  Chunker: {
    shape: class
    class: port
    +supports(type): boolean
    +chunk(raw): "List<Chunk>"
  }
  EmbeddingPort: {
    shape: class
    class: port
    +embedBatch(texts): "List<float[]>"
  }
  VectorStorePort: {
    shape: class
    class: port
    "+upsert(chunkVectors)"
    "+search(q, k, filter)": "List<ScoredId>"
  }
  ChunkRepository: {
    shape: class
    class: port
    +existsByHash(hash): boolean
    +upsert(chunk)
  }
  RelationshipRepository: {
    shape: class
    class: port
    "knowledge.graph.domain": ""
    "+upsertAll(relationships)"
  }
}

collaborators: "collaborator — knowledge.graph" {
  LinkingService: {
    shape: class
    "+link(artifact, chunks)": LinkSummary
  }
}

application: "application — pipes & filters" {
  SourceRegistered: {
    shape: class
    class: event
    +sourceId: String
  }
  IndexingService: {
    shape: class
    +onSourceRegistered(evt)
    +index(sourceId): IndexResult
  }
  Pipeline: {
    shape: class
    +run(ctx): IndexingContext
  }
  IndexingContext: {
    shape: class
    -artifacts: "List<RawArtifact>"
    -chunks: "List<Chunk>"
    -vectors: "List<ChunkVector>"
    -skipped: int
  }
  ChunkStage: {
    shape: class
    class: stage
    +apply(ctx): IndexingContext
  }
  DedupStage: {
    shape: class
    class: stage
    +apply(ctx): IndexingContext
  }
  EmbedStage: {
    shape: class
    class: stage
    +apply(ctx): IndexingContext
  }
  StoreStage: {
    shape: class
    class: stage
    +apply(ctx): IndexingContext
  }
  LinkStage: {
    shape: class
    class: stage
    +apply(ctx): IndexingContext
  }
}

inbound: "inbound adapters" {
  SourceController: {
    shape: class
    +register(req): ResponseEntity
  }
  SyncTool: {
    shape: class
    +syncSource(sourceId): String
  }
}

infraAdapters: "infrastructure — port adapters (Strategy)" {
  JavaCodeChunker: {
    shape: class
    "extends AbstractCodeChunker": "(one strategy per language)"
    +chunk(raw): "List<Chunk>"
  }
  DocChunker: {
    shape: class
    "structure-aware fallback": "(any text)"
    +chunk(raw): "List<Chunk>"
  }
  EmbeddingApiAdapter: {
    shape: class
    "@Retry @CircuitBreaker": Resilience4j
    +embedBatch(texts): "List<float[]>"
  }
  QdrantVectorAdapter: {
    shape: class
    "implements HybridVectorStore"
    "+upsert(chunkVectors)"
    "+hybridSearch(dense, sparse, k, f)"
  }
}

infraRepos: "infrastructure — repository adapters" {
  Neo4jChunkAdapter: {
    shape: class
    +upsert(chunk)
  }
  Neo4jRelationshipAdapter: {
    shape: class
    "+merge(from, to, type, confidence)"
  }
}

# inbound adapters drive the application service
inbound.SourceController -> application.IndexingService: {style.stroke-dash: 4}
inbound.SyncTool -> application.IndexingService: {style.stroke-dash: 4}

# domain event decouples the trigger (publish on register, react via listener)
application.SourceRegistered -> application.IndexingService: "@EventListener" {style.stroke-dash: 4}

# service runs the pipeline; pipeline owns the ordered stages (filled diamond = composition)
application.IndexingService -> application.Pipeline: {style.stroke-dash: 4}
application.Pipeline -> application.ChunkStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.Pipeline -> application.DedupStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.Pipeline -> application.EmbedStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.Pipeline -> application.StoreStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}
application.Pipeline -> application.LinkStage: {source-arrowhead.shape: diamond; source-arrowhead.style.filled: true}

# the pipe: context flows through filters in order
application.ChunkStage -> application.DedupStage -> application.EmbedStage -> application.StoreStage -> application.LinkStage

# each filter depends only on the domain ports it needs (dependency inward)
application.ChunkStage -> domain.Chunker: {style.stroke-dash: 4}
application.DedupStage -> domain.ChunkRepository: {style.stroke-dash: 4}
application.EmbedStage -> domain.EmbeddingPort: {style.stroke-dash: 4}
application.StoreStage -> domain.VectorStorePort: {style.stroke-dash: 4}
application.StoreStage -> domain.ChunkRepository: {style.stroke-dash: 4}
application.LinkStage -> collaborators.LinkingService: {style.stroke-dash: 4}
collaborators.LinkingService -> domain.RelationshipRepository: {style.stroke-dash: 4}

# Strategy: each port has interchangeable adapters; infra realizes ports (dashed, hollow triangle)
infraAdapters.JavaCodeChunker -> domain.Chunker: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraAdapters.DocChunker -> domain.Chunker: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraAdapters.EmbeddingApiAdapter -> domain.EmbeddingPort: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraAdapters.QdrantVectorAdapter -> domain.VectorStorePort: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraRepos.Neo4jChunkAdapter -> domain.ChunkRepository: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
infraRepos.Neo4jRelationshipAdapter -> domain.RelationshipRepository: {target-arrowhead.shape: triangle; target-arrowhead.style.filled: false; style.stroke-dash: 4}
