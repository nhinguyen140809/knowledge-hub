# Data Transformation — indexing pipeline (object flow)
# Shows the DATA OBJECT and its shape at each step of the write side, and how one record type is
# transformed into the next. Companion to the structural view CLASS-INDEXING.d2 (types + wiring)
# and the data-flow view PIPELINE-INGESTION.d2 (what happens). One run = one artifact.
# Boxes are the payloads carried by IndexingContext; edge labels are the stage that transforms them.
# Render:  d2 DATA-TRANSFORM-INDEXING.d2 data-transform-indexing.svg     (or .pdf for LaTeX)
vars: {
  d2-config: {
    layout-engine: elk
    pad: 16
  }
}
direction: down

classes: {
  data: {
    style.fill: "#2563eb"
    style.stroke: "#eef6ff"
  }
  aux: {
    style.fill: "#059669"
    style.stroke: "#ecfdf5"
  }
  store: {
    style.fill: "#7c3aed"
    style.stroke: "#f5f3ff"
  }
}

Source: {
  shape: class
  class: data
  sourceId: String
  type: SourceType
  uriOrPath: String
  ref: String
  include: "List<String>"
  ignore: "List<String>"
}

RawArtifactRaw: "RawArtifact (raw)" {
  shape: class
  class: data
  path: String
  mediaType: String
  content: "byte[]"
  text: "null (not yet read)"
  provenance: Provenance
}

Provenance: "Provenance (sealed)" {
  shape: class
  class: aux
  "FsProvenance": "sourceId, path, contentHash, indexedAt"
  "GitProvenance": "+ ref, commitSha"
}

RawArtifactText: "RawArtifact (+text)" {
  shape: class
  class: data
  path: String
  mediaType: String
  content: "byte[]"
  text: "String (extracted)"
  provenance: Provenance
}

Chunk: "List<Chunk>" {
  shape: class
  class: data
  chunkId: "String (content-addressed)"
  sourceId: String
  fileId: String
  path: String
  type: ChunkType
  text: String
  contentHash: String
  tokenCount: int
  "lineStart / lineEnd": int
  entityId: String
  provenance: Provenance
}

CodeEntity: "List<CodeEntity> (code only)" {
  shape: class
  class: aux
  entityId: String
  parentEntityId: String
  level: CodeEntityLevel
  name: String
  qualifiedName: String
  signature: String
  "lineStart / lineEnd": int
}

NewChunks: "List<Chunk> — newChunks" {
  shape: class
  class: data
  "(content-unchanged chunks dropped)": ""
  "cached: int": "count reused by hash"
}

ChunkVector: "List<ChunkVector>" {
  shape: class
  class: data
  chunkId: "String (shared with Chunk node)"
  embedding: "float[]"
  metadata: "Map<String,Object>"
}

qdrant: "Qdrant — vector point\n(from ChunkVector)" {shape: cylinder; class: store}
neo4j: "Neo4j — Chunk / CodeEntity nodes\n+ relationships" {shape: cylinder; class: store}

# ---- object flow: each edge is the stage that transforms one shape into the next ----
Source -> RawArtifactRaw: "Connector.fetch\n(walk · glob · sha256)"
RawArtifactRaw -> Provenance: carries {style.stroke-dash: 3}
RawArtifactRaw -> RawArtifactText: "DocumentReader.extractText"
RawArtifactText -> Chunk: "ChunkStage (Chunker)"
Chunk -> CodeEntity: "extracted alongside\n(structural relations)" {style.stroke-dash: 3}
Chunk -> NewChunks: "DedupStage\n(content-hash filter)"
NewChunks -> ChunkVector: "EmbedStage (EmbeddingPort)"
ChunkVector -> qdrant: "StoreStage — upsert vector"
Chunk -> neo4j: "StoreStage — merge nodes"
CodeEntity -> neo4j: "StoreStage — merge nodes" {style.stroke-dash: 3}
neo4j -> neo4j: "LinkStage — add cross-artifact\n/ cross-source edges"
